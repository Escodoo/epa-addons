<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
<template id="report_hr_attendance_sheet">
    <t t-call="web.html_container">
    <t t-call="web.basic_layout">
        <t t-set="o" t-value="doc" />
        <t t-set="company_id" t-value="o.employee_id.company_id" />
        <t t-if="company_id">
            <div>
                <div>
                    <img
                                t-if="company_id.logo"
                                t-attf-src="data:image/png;base64,#{company_id.logo}"
                                width="175"
                            />
                </div>
                <div>
                    <span t-field="company_id.name" />
                    <br />
                    <span t-field="company_id.street_name" />,
                    <span t-field="company_id.street_number" />
                    <br />
                    <span t-field="company_id.district" />
                    <br />
                    <span t-field="company_id.zip" /> -
                    <span t-field="company_id.city_id" />-<span
                                t-field="company_id.state_id.code"
                            />
                    <br />
                    <span t-field="company_id.country_id" />
                </div>
            </div>
        </t>
        <div class="page" style="margin-top: 20px;">
            <h2>
                <span>Attendance Sheet: </span>
                <span t-field="o.employee_id.name" />
            </h2>
            <div id="employee_informations" class="row">
                <div class="col-4">
                    <div>
                        <strong>CPF: </strong>
                        <span t-field="o.employee_id.cpf" />
                    </div>
                    <div class="mt-2 mb-2">
                        <strong>Função: </strong>
                        <span t-field="o.employee_id.job_id.name" />
                    </div>
                    <div class="mb-2">
                        <strong>PIS: </strong>
                        <span t-field="o.employee_id.pis_pasep" />
                    </div>
                    <div>
                        <strong>Data de Admissão: </strong>
                        <span t-field="o.employee_id.first_contract_date" />
                    </div>
                </div>
                <div class="col-6">
                    <div class="mt16 mb16">
                        <strong>Horário de Trabalho: </strong>
                    </div>
                    <t
                                t-set="calendar_lines"
                                t-value="o.employee_id.resource_calendar_id.attendance_ids"
                            />
                    <t
                                t-set="days_of_week"
                                t-value="sorted(set(calendar_lines.mapped('dayofweek')))"
                            />
                    <t t-foreach="days_of_week" t-as="day_of_week">
                        <div class="row">
                            <div class="col-4">
                                <t t-if="day_of_week == '0'">Segunda-feira</t>
                                <t t-if="day_of_week == '1'">Terça-feira</t>
                                <t t-if="day_of_week == '2'">Quarta-feira</t>
                                <t t-if="day_of_week == '3'">Quinta-feira</t>
                                <t t-if="day_of_week == '4'">Sexta-feira</t>
                                <t t-if="day_of_week == '5'">Sábado</t>
                                <t t-if="day_of_week == '6'">Domingo</t>
                            </div>
                            <t
                                        t-foreach="calendar_lines.filtered(lambda x: x.dayofweek == day_of_week)"
                                        t-as="hours"
                                    >
                                <div class="col-4">
                                    <span
                                                t-esc="hours.hour_from"
                                                t-options='{"widget": "float_time"}'
                                            />
                                    <span> - </span>
                                    <span
                                                t-esc="hours.hour_to"
                                                t-options='{"widget": "float_time"}'
                                            />
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>
            <h5 style="margin: 10px 0;">
                <span>Period: </span>
                <span t-field="o.request_date_from" />
                <span> - </span>
                <span t-field="o.request_date_to" />
                <span> - Empresa: </span>
                <span t-field="o.employee_id.company_id" />
            </h5>
            <div id="informations" class="row mt16 mb16">
                <!-- Total de Presença Planejada -->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Total Planned Attendance</strong>
                    <p
                                t-field="o.total_planned_attendance"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
                <!-- Total de Horas Extras  (Positivo)-->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Total Pos. Attendance</strong>
                    <p
                                t-field="o.total_overtime"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
                <!--
                    Total de Horas Negativa
                    Diferença de Horas, horas faltantes comparado com o estimado)
                 -->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Total Neg. Attendance</strong>
                    <p
                                t-field="o.total_difftime"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
                <!-- Total de Saldo de Horas -->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Total Attendance Balance</strong>
                    <p
                                t-esc="o.total_overtime - o.total_difftime"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
                <!-- Total de Ausência -->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Total Absence</strong>
                    <p
                                t-field="o.total_absence"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
                <!-- Total de Horas Extras -->
                <div class="col-2 bm-0" style="font-size: 12px">
                    <strong>Horas Extras</strong>
                    <p
                                t-field="o.total_sundays_holidays"
                                class="m-0"
                                t-options='{"widget": "float_time"}'
                            />
                </div>
            </div>
            <table class="table table-sm o_main_table" style="font-size: 10px">
                <thead>
                    <tr>
                        <t t-set="colspan" t-value="5" />
                        <th name="th_date" class="text-left">Date</th>
                        <th name="th_day" class="text-right">Day</th>
                        <th name="th_total_attendance" class="text-right">
                            Total Attendance
                        </th>
                        <th name="th_total_planned_attendance" class="text-right">
                            Total Planned Attendance
                        </th>
                        <th name="th_asignin" class="text-right">Signin</th>
                        <th name="th_asignout" class="text-right">Signout</th>
                        <th name="th_signin" class="text-right">Signin</th>
                        <th name="th_signout" class="text-right">Signout</th>
                        <th name="th_overtime" class="text-right">Overtime</th>
                        <th name="th_difftime" class="text-right">Diff Time</th>
                        <th name="th_status" class="text-right">Status</th>
                    </tr>
                </thead>
                <tbody class="sale_tbody">
                    <t t-foreach="doc.attendance_sheet_ids" t-as="line">
                        <tr
                                    t-if="not (line.day in ['Saturday', 'Sunday'] and line.total_attendance == 0)"
                                    class="bg-200 font-weight-bold"
                                >
                            <td name="td_date">
                                <span t-field="line.date" />
                            </td>
                            <td name="td_day" class="text-right">
                                <t t-if="line.day == 'Monday'">Segunda-feira</t>
                                <t t-if="line.day == 'Tuesday'">Terça-feira</t>
                                <t t-if="line.day == 'Wednesday'">Quarta-feira</t>
                                <t t-if="line.day == 'Thursday'">Quinta-feira</t>
                                <t t-if="line.day == 'Friday'">Sexta-feira</t>
                                <t t-if="line.day == 'Saturday'">Sábado</t>
                                <t t-if="line.day == 'Sunday'">Domingo</t>
                            </td>
                            <td name="td_total_attendance" class="text-right">
                                <span
                                            t-field="line.total_attendance"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_total_planned_attendance" class="text-right">
                                <span
                                            t-field="line.total_planned_attendance"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_asignin" class="text-right">
                                <span
                                            t-field="line.asignin"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_fsignout" class="text-right">
                                <span
                                            t-field="line.fsignout"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_lsignin" class="text-right">
                                <span
                                            t-field="line.lsignin"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_asignout" class="text-right">
                                <span
                                            t-field="line.asignout"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_overtime" class="text-right">
                                <span
                                            t-field="line.overtime"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                            <td name="td_difftime" class="text-right">
                                <span
                                            t-field="line.difftime"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>

                            <td name="td_status" class="text-right">
                                <span t-field="line.status" />
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <h3>
                <span>Attendance Detail</span>
            </h3>

            <table class="table table-sm o_main_table" style="font-size: 10px">
                <thead>
                    <tr>
                        <t t-set="colspan" t-value="5" />
                        <th name="th_check_in">Check In</th>
                        <th name="th_check_out">Check Out</th>
                        <th name="th_time_changed_manually">Time changed</th>
                        <th name="th_attendance_reason_ids">Attendance Reason</th>
                        <th name="th_worked_hours" class="text-right">Worked Hours</th>
                    </tr>
                </thead>
                <tbody class="sale_tbody">
                    <t t-foreach="doc.attendance_ids" t-as="line">
                        <tr class="bg-200 font-weight-bold">
                            <td name="td_check_in">
                                <span t-field="line.check_in" />
                            </td>
                            <td name="td_check_out">
                                <span t-field="line.check_out" />
                            </td>
                            <td name="td_time_changed_manually">
                                <span t-field="line.time_changed_manually" />
                            </td>
                            <td name="td_attendance_reason_ids">
                                <span t-field="line.attendance_reason_ids" />
                            </td>
                            <td name="td_worked_hours" class="text-right">
                                <span
                                            t-field="line.worked_hours"
                                            t-options='{"widget": "float_time"}'
                                        />
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="row" style="margin-top: 12rem;">
                <div class="col-6" />
                <div class="col-6 text-right">
                    <span>
                        ___________________________________________________________________
                    </span>
                    <div>
                        <span>Assinatura do funcionário</span>
                    </div>
                </div>
            </div>
        </div>
    </t>
    </t>
</template>

<template id="main_report_hr_attendance_sheet">
    <t t-call="web.html_container">
        <t t-set="data_report_margin_top" t-value="12" />
        <t t-set="full_width" t-value="True" />
        <t t-foreach="docs" t-as="doc">
            <t t-call="epa_hr_attendances_overtime_custom.report_hr_attendance_sheet" />
        </t>
    </t>
</template>

</odoo>
